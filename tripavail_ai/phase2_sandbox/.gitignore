# Phase 2 Sandbox .gitignore
# ===========================

# Sandbox environment (DO NOT COMMIT CREDENTIALS!)
.env_sandbox

# Sandbox data and logs
data/*
logs/*
*.log

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Test outputs
test_output/
temp_*

# Keep directory structure but ignore contents
!data/.gitkeep
!logs/.gitkeep

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
