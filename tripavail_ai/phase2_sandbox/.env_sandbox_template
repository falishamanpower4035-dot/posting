# Phase 2 Sandbox Environment Variables
# ========================================
# COPY this file to .env_sandbox and fill in TEST credentials
# NEVER use production API keys here!

# Sandbox Mode Flag
SANDBOX_MODE=true
SANDBOX_VERSION=2.0

# Test API Keys (Use test/development keys only!)
# ================================================

# OpenAI (Use a separate test project key)
OPENAI_API_KEY=sk-test-your-test-key-here

# Google Gemini (Test project)
GOOGLE_API_KEY=test-key-here

# ElevenLabs (Development tier)
ELEVENLABS_API_KEY=test-key-here

# Stock Photos (Test accounts with limited quota)
# ================================================
SHUTTERSTOCK_ACCESS_TOKEN=test-token-here
SHUTTERSTOCK_CLIENT_ID=test-client-id
SHUTTERSTOCK_CLIENT_SECRET=test-client-secret

PEXELS_API_KEY=test-key-here
UNSPLASH_ACCESS_KEY=test-key-here

# Stability AI (Test key)
STABILITY_KEY=test-key-here

# Social Media (Test accounts ONLY!)
# ===================================
# Use test accounts, not production social media accounts!

INSTAGRAM_USERNAME=test_account
INSTAGRAM_PASSWORD=test_password

FACEBOOK_ACCESS_TOKEN=test-token
FACEBOOK_PAGE_ID=test-page-id

YOUTUBE_CLIENT_ID=test-client-id
YOUTUBE_CLIENT_SECRET=test-client-secret

# Cloud Storage (Separate test bucket/folder)
# ============================================
DROPBOX_ACCESS_TOKEN=test-token
DROPBOX_APP_KEY=test-app-key
DROPBOX_APP_SECRET=test-app-secret

# Notification (Test email)
# ==========================
NOTIFY_EMAIL=your-test-email@example.com

# Database/Storage Paths (Sandbox-specific)
# ==========================================
DATA_DIR=./data
LOGS_DIR=./logs
ASSETS_DIR=../assets  # Share assets with production

# Feature Flags for Phase 2 Experiments
# ======================================
EXPERIMENTAL_GPT4O=false
EXPERIMENTAL_CLAUDE=false
EXPERIMENTAL_TIKTOK=false
EXPERIMENTAL_ADVANCED_SCORING=false
EXPERIMENTAL_MULTI_LANGUAGE=false

# Rate Limits (Lower for testing)
# ================================
MAX_POSTS_PER_DAY=5
MAX_API_CALLS_PER_HOUR=100

# Debug Settings
# ==============
DEBUG_MODE=true
VERBOSE_LOGGING=true
DRY_RUN=true  # Prevent actual social media posting during tests
